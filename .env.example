# GitHub OAuth App — register at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Random 32-byte base64 string — encrypts OAuth tokens at rest in SQLite.
# Generate with:  openssl rand -base64 32
HARNESS_TOKEN_ENCRYPTION_KEY=

# Where SQLite lives. Defaults to ./data/harness.db
HARNESS_DB_PATH=./data/harness.db

# OpenAI Codex login uses the upstream codex CLI client_id automatically;
# nothing to configure here unless you want to override the local callback port.
# CODEX_CALLBACK_PORT=1455
